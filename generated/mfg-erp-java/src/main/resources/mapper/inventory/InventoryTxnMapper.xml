<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mfgerp.domain.inventory.mapper.InventoryTxnMapper">

    <resultMap id="InventoryTxnResultMap" type="com.example.mfgerp.domain.inventory.entity.InventoryTxn">
        <id property="txnId" column="txn_id"/>
        <result property="txnNo" column="txn_no"/>
        <result property="itemId" column="item_id"/>
        <result property="warehouseId" column="warehouse_id"/>
        <result property="lotId" column="lot_id"/>
        <result property="txnType" column="txn_type"/>
        <result property="direction" column="direction"/>
        <result property="quantity" column="quantity"/>
        <result property="unitCost" column="unit_cost"/>
        <result property="totalCost" column="total_cost"/>
        <result property="qtyBefore" column="qty_before"/>
        <result property="qtyAfter" column="qty_after"/>
        <result property="txnDate" column="txn_date"/>
        <result property="txnTime" column="txn_time"/>
        <result property="refDocType" column="ref_doc_type"/>
        <result property="refDocId" column="ref_doc_id"/>
        <result property="operator" column="operator"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 翻译自 INVENTORY_PKG.archive_txns_before -->
    <!-- 对应 PL/SQL: execute immediate 'create table ' || v_tab || ' as select * from t_inventory_txn where 1 = 0' -->
    <update id="createArchiveTable">
        CREATE TABLE IF NOT EXISTS ${tableName} AS SELECT * FROM t_inventory_txn WHERE 1 = 0
    </update>

    <!-- 对应 PL/SQL: execute immediate 'insert into ' || v_tab || ' select * from t_inventory_txn where txn_date < :1' -->
    <insert id="archiveToTable">
        INSERT INTO ${tableName} SELECT * FROM t_inventory_txn WHERE txn_date &lt; #{beforeDate}
    </insert>

    <!-- 对应 PL/SQL: execute immediate 'delete from t_inventory_txn where txn_date < :1' -->
    <delete id="deleteArchived">
        DELETE FROM t_inventory_txn WHERE txn_date &lt; #{beforeDate}
    </delete>

    <!--
        对应 PL/SQL adjust_stock/transfer_stock 中的流水类型改记:
        update t_inventory_txn
           set txn_type = :newType, remark = :remark
         where item_id = :itemId
           and warehouse_id = :warehouseId
           and txn_type = :oldType
           and txn_date = :txnDate
           and ref_doc_type = :refDocType
    -->
    <update id="updateTxnTypeByCriteria">
        UPDATE t_inventory_txn
           SET txn_type = #{newType},
               remark   = #{remark}
         WHERE item_id      = #{itemId}
           AND warehouse_id = #{warehouseId}
           AND txn_type     = #{oldType}
           AND txn_date     = #{txnDate}
           AND ref_doc_type = #{refDocType}
    </update>

</mapper>
