<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mfgerp.domain.item.mapper.CategoryMapper">

    <resultMap id="ItemCategoryResultMap" type="com.example.mfgerp.domain.item.entity.ItemCategory">
        <id property="categoryId" column="category_id"/>
        <result property="parentCategoryId" column="parent_category_id"/>
        <result property="categoryCode" column="category_code"/>
        <result property="categoryName" column="category_name"/>
        <result property="levelNo" column="level_no"/>
        <result property="path" column="path"/>
        <result property="isLeaf" column="is_leaf"/>
    </resultMap>

</mapper>
