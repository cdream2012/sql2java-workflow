<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mfgerp.domain.item.mapper.ItemMapper">

    <!-- Item 实体映射 -->
    <resultMap id="ItemResultMap" type="com.example.mfgerp.domain.item.entity.Item">
        <id property="itemId" column="item_id"/>
        <result property="itemCode" column="item_code"/>
        <result property="itemName" column="item_name"/>
        <result property="itemType" column="item_type"/>
        <result property="categoryId" column="category_id"/>
        <result property="baseUom" column="base_uom"/>
        <result property="stdCost" column="std_cost"/>
        <result property="listPrice" column="list_price"/>
        <result property="currencyCode" column="currency_code"/>
        <result property="valuationMethod" column="valuation_method"/>
        <result property="preferredSupplier" column="preferred_supplier"/>
        <result property="leadTimeDays" column="lead_time_days"/>
        <result property="safetyStock" column="safety_stock"/>
        <result property="reorderPoint" column="reorder_point"/>
        <result property="reorderQty" column="reorder_qty"/>
        <result property="shelfLifeDays" column="shelf_life_days"/>
        <result property="abcClass" column="abc_class"/>
        <result property="isPhantom" column="is_phantom"/>
        <result property="isLotControlled" column="is_lot_controlled"/>
        <result property="status" column="status"/>
        <result property="dim" column="dim"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="tags" column="tags"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- ItemVO 结果映射 -->
    <resultMap id="ItemVOResultMap" type="com.example.mfgerp.domain.item.dto.ItemVO">
        <result property="itemId" column="item_id"/>
        <result property="itemCode" column="item_code"/>
        <result property="itemName" column="item_name"/>
        <result property="itemType" column="item_type"/>
        <result property="baseUom" column="base_uom"/>
        <result property="stdCost" column="std_cost"/>
        <result property="listPrice" column="list_price"/>
        <result property="valuationMethod" column="valuation_method"/>
    </resultMap>

    <!-- 翻译自 ITEM_PKG.get_item_obj -->
    <!-- 原始 PL/SQL 使用 v_item_full 视图, Java 中直接查询 -->
    <select id="getItemObj" resultMap="ItemVOResultMap">
        SELECT item_id, item_code, item_name, item_type, base_uom,
               std_cost, list_price, valuation_method, status
        FROM v_item_full
        WHERE item_id = #{itemId}
    </select>

    <!-- 翻译自 ITEM_PKG.get_item -->
    <!-- 对应 PL/SQL: select * into v_item from t_item where item_id = p_item_id -->
    <select id="getItem" resultMap="ItemResultMap">
        SELECT * FROM t_item WHERE item_id = #{itemId}
    </select>

    <!-- 翻译自 INVENTORY_PKG.receive_stock (by code) 的物料查询 -->
    <!-- 对应 PL/SQL: select item_id, std_cost into v_item_id, v_std_cost from t_item where item_code = p_item_code -->
    <select id="getItemByCode" resultMap="ItemResultMap">
        SELECT * FROM t_item WHERE item_code = #{itemCode}
    </select>

    <!-- 翻译自 ITEM_PKG.find_item_id -->
    <!-- 对应 PL/SQL: select item_id into v_id from t_item where item_code = p_item_code -->
    <select id="findItemId" resultType="java.lang.Long">
        SELECT item_id FROM t_item WHERE item_code = #{itemCode}
    </select>

    <!-- 翻译自 ITEM_PKG.get_category_path -->
    <!-- 对应 PL/SQL:
         select sys_connect_by_path(category_code, '/') into v_path
           from t_item_category
          where category_id = p_category_id
         start with parent_category_id is null
         connect by prior category_id = parent_category_id;
         MySQL 8.0+ 用递归 CTE 替代 CONNECT BY
    -->
    <select id="getCategoryPath" resultType="java.lang.String">
        WITH RECURSIVE cat_tree AS (
            SELECT category_id, parent_category_id, category_code,
                   CAST(category_code AS CHAR(500)) AS path
              FROM t_item_category
             WHERE parent_category_id IS NULL
            UNION ALL
            SELECT c.category_id, c.parent_category_id, c.category_code,
                   CONCAT(ct.path, '/', c.category_code)
              FROM t_item_category c
              JOIN cat_tree ct ON c.parent_category_id = ct.category_id
        )
        SELECT path FROM cat_tree WHERE category_id = #{categoryId}
    </select>

    <!-- 翻译自 ITEM_PKG.list_category_subtree -->
    <!-- 对应 PL/SQL:
         select category_id, parent_category_id, category_code, category_name,
                level as lvl, connect_by_isleaf as is_leaf_calc,
                connect_by_root category_code as root_code,
                sys_connect_by_path(category_code, '/') as path
           from t_item_category
         start with category_id = p_root_category_id
         connect by prior category_id = parent_category_id
          order siblings by category_code;
    -->
    <resultMap id="CategoryVOResultMap" type="com.example.mfgerp.domain.item.dto.CategoryVO">
        <result property="categoryId" column="category_id"/>
        <result property="parentCategoryId" column="parent_category_id"/>
        <result property="categoryCode" column="category_code"/>
        <result property="categoryName" column="category_name"/>
        <result property="levelNo" column="lvl"/>
        <result property="isLeaf" column="is_leaf_calc"/>
        <result property="path" column="path"/>
    </resultMap>

    <select id="listCategorySubtree" resultMap="CategoryVOResultMap">
        WITH RECURSIVE cat_tree AS (
            SELECT category_id, parent_category_id, category_code, category_name,
                   1 AS lvl,
                   CAST(category_code AS CHAR(500)) AS path
              FROM t_item_category
             WHERE category_id = #{rootCategoryId}
            UNION ALL
            SELECT c.category_id, c.parent_category_id, c.category_code, c.category_name,
                   ct.lvl + 1,
                   CONCAT(ct.path, '/', c.category_code)
              FROM t_item_category c
              JOIN cat_tree ct ON c.parent_category_id = ct.category_id
        )
        SELECT category_id, parent_category_id, category_code, category_name,
               lvl,
               CASE WHEN NOT EXISTS (
                   SELECT 1 FROM t_item_category child WHERE child.parent_category_id = cat_tree.category_id
               ) THEN true ELSE false END AS is_leaf_calc,
               path
          FROM cat_tree
         ORDER BY path
    </select>

    <!-- 翻译自 ITEM_PKG.rebuild_category_tree -->
    <!-- 对应 PL/SQL:
         merge into t_item_category tgt
         using (select category_id, level as level_no,
                       sys_connect_by_path(category_code, '/') as path,
                       case connect_by_isleaf when 1 then 'Y' else 'N' end as is_leaf
                  from t_item_category
                start with parent_category_id is null
                connect by prior category_id = parent_category_id) src
         on (tgt.category_id = src.category_id)
         when matched then update set tgt.level_no = src.level_no, tgt.path = src.path, tgt.is_leaf = src.is_leaf;
    -->
    <update id="rebuildCategoryTree">
        WITH RECURSIVE cat_tree AS (
            SELECT category_id,
                   1 AS level_no,
                   CAST(category_code AS CHAR(500)) AS path,
                   CASE WHEN NOT EXISTS (
                       SELECT 1 FROM t_item_category child WHERE child.parent_category_id = t_item_category.category_id
                   ) THEN 'Y' ELSE 'N' END AS is_leaf
              FROM t_item_category
             WHERE parent_category_id IS NULL
            UNION ALL
            SELECT c.category_id,
                   ct.level_no + 1,
                   CONCAT(ct.path, '/', c.category_code),
                   CASE WHEN NOT EXISTS (
                       SELECT 1 FROM t_item_category child WHERE child.parent_category_id = c.category_id
                   ) THEN 'Y' ELSE 'N' END
              FROM t_item_category c
              JOIN cat_tree ct ON c.parent_category_id = ct.category_id
        )
        UPDATE t_item_category tgt
        INNER JOIN cat_tree src ON tgt.category_id = src.category_id
           SET tgt.level_no = src.level_no,
               tgt.path     = src.path,
               tgt.is_leaf  = src.is_leaf
    </update>

    <!-- 翻译自 ITEM_PKG.reclassify_abc -->
    <!-- 对应 PL/SQL:
         merge into t_item tgt
         using (select item_id,
                       case when cum_pct &lt;= v_a_pct then 'A'
                            when cum_pct &lt;= v_b_pct then 'B' else 'C' end as abc_class
                  from (select item_id,
                               sum(consume_amt) over (order by consume_amt desc, item_id)
                                   / nullif(sum(consume_amt) over (), 0) as cum_pct
                          from (select item_id, sum(total_cost) as consume_amt
                                  from t_inventory_txn
                                 where direction = 'O' and txn_date between p_from_date and p_to_date
                                 group by item_id having sum(total_cost) > 0))) src
         on (tgt.item_id = src.item_id)
         when matched then update set tgt.abc_class = src.abc_class, tgt.updated_by = ..., tgt.updated_at = ...;
    -->
    <update id="reclassifyAbc">
        UPDATE t_item tgt
        INNER JOIN (
            SELECT item_id,
                   CASE
                       WHEN cum_pct &lt;= #{aPct} THEN 'A'
                       WHEN cum_pct &lt;= #{bPct} THEN 'B'
                       ELSE 'C'
                   END AS abc_class
              FROM (
                    SELECT item_id,
                           SUM(consume_amt) OVER (ORDER BY consume_amt DESC, item_id)
                               / NULLIF(SUM(consume_amt) OVER (), 0) AS cum_pct
                      FROM (
                            SELECT item_id, SUM(total_cost) AS consume_amt
                              FROM t_inventory_txn
                             WHERE direction = 'O'
                               AND txn_date BETWEEN #{fromDate} AND #{toDate}
                             GROUP BY item_id
                            HAVING SUM(total_cost) > 0
                           )
                   )
        ) src ON tgt.item_id = src.item_id
           SET tgt.abc_class = src.abc_class,
               tgt.updated_by = 'SYSTEM',
               tgt.updated_at = CURRENT_TIMESTAMP
    </update>

    <!-- 翻译自 ITEM_PKG.apply_item_flat -->
    <!-- 对应 PL/SQL: update t_item set item_name=..., std_cost=..., ... where item_id = p_item_id -->
    <update id="applyItemFlat">
        UPDATE t_item
           SET item_name  = #{itemName},
               std_cost   = COALESCE(#{stdCost}, std_cost),
               list_price = COALESCE(#{listPrice}, list_price),
               status     = COALESCE(#{status}, status),
               dim        = #{dim, typeHandler=com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler},
               updated_by = 'SYSTEM',
               updated_at = CURRENT_TIMESTAMP
         WHERE item_id = #{itemId}
    </update>

</mapper>
