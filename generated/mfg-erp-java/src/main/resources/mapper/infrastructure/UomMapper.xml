<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mfgerp.infrastructure.util.UomMapper">

    <!-- UOM 实体映射 -->
    <resultMap id="UomResultMap" type="com.example.mfgerp.infrastructure.entity.Uom">
        <id property="uomCode" column="uom_code"/>
        <result property="uomName" column="uom_name"/>
        <result property="uomCategory" column="uom_category"/>
        <result property="decimalDigits" column="decimal_digits"/>
        <result property="isBase" column="is_base"/>
    </resultMap>

    <!-- UOM Conversion 实体映射 -->
    <resultMap id="UomConversionResultMap" type="com.example.mfgerp.infrastructure.entity.UomConversion">
        <id property="fromUom" column="from_uom"/>
        <result property="toUom" column="to_uom"/>
        <result property="factor" column="factor"/>
    </resultMap>

</mapper>
