<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mfgerp.infrastructure.exception.ErrorLogMapper">

    <!-- 翻译自 EXC_PKG.log_error 的 INSERT 语句 -->
    <!-- 使用 MyBatis-Plus BaseMapper.insert() 即可，无需额外 SQL -->

    <!-- 结果映射 -->
    <resultMap id="ErrorLogResultMap" type="com.example.mfgerp.infrastructure.entity.ErrorLog">
        <id property="logId" column="log_id"/>
        <result property="errorCode" column="error_code"/>
        <result property="errorLevel" column="error_level"/>
        <result property="moduleName" column="module_name"/>
        <result property="procedureName" column="procedure_name"/>
        <result property="errorMsg" column="error_msg"/>
        <result property="errorStack" column="error_stack"/>
        <result property="bizKey" column="biz_key"/>
        <result property="contextData" column="context_data"/>
        <result property="operator" column="operator"/>
        <result property="occurredAt" column="occurred_at"/>
    </resultMap>

</mapper>
