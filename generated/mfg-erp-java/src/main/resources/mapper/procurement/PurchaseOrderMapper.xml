<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mfgerp.domain.procurement.mapper.PurchaseOrderMapper">

    <!-- 翻译自 PROCUREMENT_PKG.refresh_po_header_status -->
    <!-- 对应 PL/SQL: 根据行状态汇总更新 PO 头状态 -->
    <update id="refreshPoHeaderStatus">
        UPDATE t_purchase_order po
           SET po.status = (
                   SELECT CASE
                              WHEN COUNT(*) = 0 THEN po.status
                              WHEN SUM(CASE WHEN pl.line_status = 'CLOSED' THEN 1 ELSE 0 END) = COUNT(*)
                                   THEN 'CLOSED'
                              WHEN SUM(CASE WHEN pl.line_status IN ('OPEN') THEN 1 ELSE 0 END) = COUNT(*)
                                   THEN 'DRAFT'
                              ELSE 'PARTIAL_RECEIVED'
                              END
                     FROM t_po_line pl
                    WHERE pl.po_id = #{poId}
               )
         WHERE po.po_id = #{poId}
    </update>

    <!-- 翻译自 PROCUREMENT_PKG.create_po_from_mrp -->
    <!-- 对应 PL/SQL: 按 MRP 计划单的净需求生成 PO -->
    <insert id="createPoFromMrp">
        <!-- TODO: [translate] 完整实现需要从 MRP 计划单聚合净需求并生成 PO + PO 行 -->
        <!-- 骨架: INSERT INTO t_purchase_order (...) SELECT ... FROM t_mrp_plan WHERE run_id = #{runId} -->
        SELECT 1
    </insert>

    <!-- 翻译自 PROCUREMENT_PKG.reorder_scan -->
    <!-- 对应 PL/SQL: 补货扫描 - 对低于再订购点的物料自动建 PO -->
    <insert id="reorderScan">
        <!-- TODO: [translate] 完整实现需要对低于再订购点的物料生成 PO -->
        <!-- 骨架: INSERT INTO t_purchase_order (...) SELECT ... FROM t_item i WHERE i.reorder_point > (SELECT qty_on_hand FROM ...) -->
        SELECT 1
    </insert>

    <select id="supplierRanking" resultType="com.example.mfgerp.domain.procurement.dto.PoVO">
        <!-- TODO: translate from PROCUREMENT_PKG.supplier_ranking -->
        SELECT NULL AS supplier_id, NULL AS supplier_name, 0 AS total_amount, 0 AS order_count
         WHERE 1 = 0
    </select>

</mapper>
