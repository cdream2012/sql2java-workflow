<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mfgerp.application.report.mapper.InventoryReportMapper">

    <select id="inventoryByWarehouse" resultType="com.example.mfgerp.application.report.dto.InventoryByWarehouseVO">
        <!-- TODO: translate from REPORT_PKG.inventory_by_warehouse -->
        SELECT NULL AS warehouse_id, NULL AS warehouse_name, 0 AS qty_on_hand WHERE 1=0
    </select>

    <select id="stockAging" resultType="com.example.mfgerp.application.report.dto.StockAgingVO">
        <!-- TODO: translate from REPORT_PKG.stock_aging -->
        SELECT NULL AS item_id, 0 AS aging_days, 0 AS qty WHERE 1=0
    </select>

    <select id="topConsumedItems" resultType="com.example.mfgerp.application.report.dto.TopConsumedItemVO">
        <!-- TODO: translate from REPORT_PKG.top_consumed_items -->
        SELECT NULL AS item_id, NULL AS item_code, 0 AS total_consumed WHERE 1=0
    </select>

    <select id="inventoryPareto" resultType="com.example.mfgerp.application.report.dto.InventoryParetoVO">
        <!-- TODO: translate from REPORT_PKG.inventory_pareto -->
        SELECT NULL AS item_id, 0 AS cumulative_pct, 0 AS total_value WHERE 1=0
    </select>

</mapper>
