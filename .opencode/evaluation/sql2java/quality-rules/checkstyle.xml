<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  SQL2Java 代码质量检查规则
  映射 .opencode/docs/java-code-spec.md 中的【强制】条款
  用于 L2 评估阶段的确定性规约检查

  规则来源标注格式: java-code-spec (X) Y.Z
    X = 章节编号 (一~八)
    Y = 条款编号
    Z = 子项编号
-->
<module name="Checker">
    <property name="severity" value="warning"/>
    <property name="charset" value="UTF-8"/>
    <property name="fileExtensions" value="java"/>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- (三) 代码格式                                       -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- 3.8 单行不超过 120 字符 -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package|^import|href|http|https|@see|@link"/>
        <message key="maxLineLen"
                 value="行宽超过 120 字符（java-code-spec 三.8）"/>
    </module>

    <!-- 3.10 文件编码 UTF-8，换行符 Unix -->
    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf"/>
    </module>

    <module name="TreeWalker">

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- (一) 命名风格                                       -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 1.1 命名不以下划线或美元符号开始/结束 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="[\$][_]|[_][\$]"/>
            <property name="message"
                      value="命名不能包含下划线与美元符号相邻（java-code-spec 一.1）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 1.3 类名 UpperCamelCase -->
        <module name="TypeName">
            <property name="format"
                      value="^[A-Z][a-zA-Z0-9]*(DO|BO|DTO|VO|AO|PO|UID|Impl|Service|Mapper|Enum|Exception|Test|Util|Config|Interceptor|Handler|Factory|Strategy|Template|Context)$|^[A-Z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="类名 ''{0}'' 不符合 UpperCamelCase（java-code-spec 一.3）"/>
        </module>

        <!-- 1.4 方法名 lowerCamelCase -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="方法名 ''{0}'' 不符合 lowerCamelCase（java-code-spec 一.4）"/>
        </module>

        <!-- 1.4 参数名 lowerCamelCase -->
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="参数名 ''{0}'' 不符合 lowerCamelCase（java-code-spec 一.4）"/>
        </module>

        <!-- 1.4 成员变量 lowerCamelCase -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="成员变量 ''{0}'' 不符合 lowerCamelCase（java-code-spec 一.4）"/>
        </module>

        <!-- 1.4 局部变量 lowerCamelCase -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="局部变量 ''{0}'' 不符合 lowerCamelCase（java-code-spec 一.4）"/>
        </module>

        <!-- 1.5 常量全大写下划线 -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$|^log(ger)?$"/>
            <message key="name.invalidPattern"
                     value="常量名 ''{0}'' 应全大写下划线分隔（java-code-spec 一.5）"/>
        </module>

        <!-- 1.6 抽象类 Abstract/Base 开头 -->
        <module name="AbstractClassName">
            <property name="format" value="^(Abstract|Base).*$"/>
            <property name="ignoreModifier" value="false"/>
            <message key="name.invalidPattern"
                     value="抽象类 ''{0}'' 应以 Abstract 或 Base 开头（java-code-spec 一.6）"/>
        </module>

        <!-- 1.9 包名全小写 -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
            <message key="name.invalidPattern"
                     value="包名 ''{0}'' 应全小写（java-code-spec 一.9）"/>
        </module>

        <!-- 1.8 布尔属性无 is 前缀 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="private\s+(boolean|Boolean)\s+is[A-Z]"/>
            <property name="message"
                      value="POJO 布尔属性不要加 is 前缀（java-code-spec 一.8）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- (二) 常量定义                                       -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 2.2 long 赋值用大写 L -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\b\d+l\b"/>
            <property name="message"
                      value="long 赋值应使用大写 L，不要用小写 l（java-code-spec 二.2）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- (三) 代码格式（TreeWalker 部分）                     -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 3.5 4 空格缩进，禁止 tab -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="8"/>
            <property name="lineWrappingIndentation" value="8"/>
            <message key="indentation.error"
                     value="缩进不正确，应使用 4 空格（java-code-spec 三.5）"/>
        </module>

        <module name="RegexpSinglelineJava">
            <property name="format" value="^\t"/>
            <property name="message"
                      value="禁止使用 tab 缩进，应使用 4 空格（java-code-spec 三.5）"/>
        </module>

        <!-- 3.3 if/for/while 与括号间加空格 -->
        <module name="WhitespaceAfter">
            <property name="tokens" value="COMMA, SEMI"/>
            <message key="ws.notFollowed"
                     value="逗号/分号后需要空格（java-code-spec 三.3/三.9）"/>
        </module>

        <module name="WhitespaceAround">
            <property name="tokens"
                      value="ASSIGN, BAND, BAND_ASSIGN, BOR, BOR_ASSIGN, BSR, BSR_ASSIGN,
                             BXOR, BXOR_ASSIGN, COLON, DIV, DIV_ASSIGN, EQUAL, GE, GT,
                             LAND, LCURLY, LE, LITERAL_ASSERT, LITERAL_CATCH,
                             LITERAL_DO, LITERAL_ELSE, LITERAL_FINALLY,
                             LITERAL_FOR, LITERAL_IF, LITERAL_RETURN, LITERAL_SWITCH,
                             LITERAL_SYNCHRONIZED, LITERAL_TRY, LITERAL_WHILE,
                             LOR, LT, MINUS, MINUS_ASSIGN, MOD, MOD_ASSIGN,
                             NOT_EQUAL, PLUS, PLUS_ASSIGN, QUESTION, RCURLY,
                             SL, SLIST, SL_ASSIGN, SR, SR_ASSIGN, STAR, STAR_ASSIGN,
                             TYPE_EXTENSION_AND"/>
            <message key="ws.notFollowed"
                     value="运算符两侧需要空格（java-code-spec 三.4）"/>
            <message key="ws.notPreceded"
                     value="运算符两侧需要空格（java-code-spec 三.4）"/>
        </module>

        <module name="ParenPad">
            <property name="option" value="nospace"/>
            <message key="ws.followed"
                     value="左括号后不应有空格（java-code-spec 三.2）"/>
            <message key="ws.preceded"
                     value="右括号前不应有空格（java-code-spec 三.2）"/>
        </module>

        <!-- 3.6 双斜杠与注释内容间有且仅有一个空格 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\s*//[^ /\n]"/>
            <property name="message"
                      value="双斜杠与注释内容之间应有且仅有一个空格（java-code-spec 三.6）"/>
            <property name="ignoreComments" value="false"/>
        </module>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- (四) OOP 规约                                       -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 4.2 覆写方法必须加 @Override -->
        <module name="MissingOverride">
            <message key="annotation.missing.override"
                     value="覆写方法必须加 @Override 注解（java-code-spec 四.2）"/>
        </module>

        <!-- 4.10 禁止 BigDecimal(double) 构造 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="new\s+BigDecimal\s*\(\s*\d+\.\d+"/>
            <property name="message"
                      value="禁止使用 BigDecimal(double)，应用 BigDecimal(String) 或 valueOf（java-code-spec 四.10）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 4.14 构造方法禁止业务逻辑（近似：构造方法行数不超过 5 行） -->
        <!-- 此项难以用 Checkstyle 精确检查，留给 review 阶段 -->

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- (五) 集合与异常                                     -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 5.x 禁止空 catch 块 -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignore|ignored"/>
            <message key="catch.block.empty"
                     value="禁止空 catch 块（java-code-spec 五.异常）"/>
        </module>

        <!-- 5.x entrySet 遍历（近似：检测 keySet 后跟 get 调用） -->
        <!-- 此项难以用 Checkstyle 精确检查，留给 review 阶段 -->

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- (五扩展) 方法质量 — 对应评审反馈 #4                    -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 3.11 单方法不超过 80 行 -->
        <module name="MethodLength">
            <property name="max" value="80"/>
            <property name="countEmpty" value="false"/>
            <message key="maxLen.method"
                     value="方法超过 80 行，应拆分（java-code-spec 三.11）"/>
        </module>

        <!-- 方法圈复杂度不超过 10 -->
        <module name="CyclomaticComplexity">
            <property name="max" value="10"/>
            <message key="cyclomaticComplexity.tooHigh"
                     value="圈复杂度超过 10，应拆分简化（java-code-spec 方法质量）"/>
        </module>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Java 8 合规检查（禁止 Java 9+ 语法和 API）           -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 禁止 var 关键字（Java 10+） -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\s*var\s+\w+\s*="/>
            <property name="message"
                      value="禁止使用 var 关键字（Java 10+），必须显式声明类型（java-code-spec Java8-1）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 List.of / Map.of / Set.of（Java 9+） -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\b(List|Map|Set)\.of\s*\("/>
            <property name="message"
                      value="禁止使用 List.of/Map.of/Set.of（Java 9+），应用 Arrays.asList/Collections.unmodifiable（java-code-spec Java8-2）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 Optional Java 9+ 方法 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\.ifPresentOrElse\s*\(|\.or\s*\(\s*\)|\.stream\s*\(\s*\)"/>
            <property name="message"
                      value="禁止使用 Optional Java 9+ 方法（java-code-spec Java8-3）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 Stream Java 9+ 方法 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\.takeWhile\s*\(|\.dropWhile\s*\(|Stream\.ofNullable\s*\("/>
            <property name="message"
                      value="禁止使用 Stream Java 9+ 方法（java-code-spec Java8-4）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 String Java 11+ 方法 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\.isBlank\s*\(\)|\.strip\s*\(\)|\.stripLeading\s*\(\)|\.stripTrailing\s*\(\)|\.lines\s*\(\)|\.repeat\s*\("/>
            <property name="message"
                      value="禁止使用 String Java 11+ 方法（isBlank/strip/lines/repeat），应用 trim() 等替代（java-code-spec Java8-5）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 HttpClient API（Java 11+） -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\bHttpClient\b|\bHttpRequest\b|\bHttpResponse\b"/>
            <property name="message"
                      value="禁止使用 HttpClient API（Java 11+）（java-code-spec Java8-6）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 switch 表达式（Java 12+，箭头语法） -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="case\s+[^:]+->"/>
            <property name="message"
                      value="禁止使用 switch 表达式箭头语法（Java 12+），应使用传统 switch（java-code-spec Java8-10）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 record 关键字（Java 14+） -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\s*(public|private|protected|)\s*record\s+\w+"/>
            <property name="message"
                      value="禁止使用 record 关键字（Java 14+），应使用传统 class（java-code-spec Java8-7）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止 sealed / permits（Java 15+） -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\s*sealed\s+(class|interface)|\bpermits\s+"/>
            <property name="message"
                      value="禁止使用 sealed/permits（Java 15+）（java-code-spec Java8-8）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- 禁止文本块 """（Java 13+） -->
        <module name="RegexpSinglelineJava">
            <property name="format" value='&quot;&quot;&quot;'/>
            <property name="message"
                      value="禁止使用文本块 (&quot;&quot;&quot;)（Java 13+），应使用字符串拼接（java-code-spec Java8-9）"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- (八) 注释规约                                       -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 8.x 检测英文注释（近似：连续 3+ 个 ASCII 单词且无中文字符的 // 注释） -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\s*//\s+[A-Z][a-z]+\s+[a-z]+\s+[a-z]+\s*[a-z]*[^一-龥]*$"/>
            <property name="message"
                      value="疑似英文注释，应使用中文注释（java-code-spec 八.注释规约）"/>
            <property name="ignoreComments" value="false"/>
        </module>

        <!-- 8.x Javadoc 格式 -->
        <module name="JavadocStyle">
            <property name="checkFirstSentence" value="false"/>
            <property name="checkEmptyJavadoc" value="false"/>
            <property name="checkHtml" value="false"/>
        </module>

    </module>
</module>
